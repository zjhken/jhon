{
	"compilerOptions": {
		"module": "ES2020",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"outDir": "out",
		"lib": [
			"ES2020"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": [
			"bun"
		]
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}