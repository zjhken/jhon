{
  "name": "jhon-syntax-highlight",
  "displayName": "JHON (JinHui's Object Notation) Language Support",
  "description": "Syntax highlighting, formatting, and diagnostics for JHON (JinHui's Object Notation)",
  "version": "2.1.0",
  "publisher": "JinhuiZhang",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zjhken/jhon.git"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "jhon",
    "syntax",
    "highlighting",
    "configuration",
    "json",
    "formatter",
    "format"
  ],
  "activationEvents": [
    "onLanguage:jhon"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "jhon",
        "aliases": [
          "JHON",
          "jhon"
        ],
        "extensions": [
          ".jhon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jhon",
        "scopeName": "source.jhon",
        "path": "./syntaxes/jhon.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "jhon.formatCompact",
        "title": "Format to One Line",
        "category": "JHON"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "jhon.formatCompact",
          "when": "editorLangId == jhon"
        }
      ]
    },
    "configuration": {
      "title": "JHON",
      "properties": {
        "jhon.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the default JHON formatter"
        },
        "jhon.format.insertSpaces": {
          "type": "boolean",
          "default": false,
          "description": "Use spaces for indentation (vs. tabs)"
        },
        "jhon.format.tabSize": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 16,
          "description": "Number of spaces or size of tab for indentation"
        },
        "jhon.format.sortKeys": {
          "type": "boolean",
          "default": false,
          "description": "Sort object keys alphabetically (default preserves insertion order per SPEC)"
        },
        "jhon.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable live parse-error diagnostics (red squiggles + Problems panel)"
        },
        "jhon.diagnostics.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 5000,
          "description": "Debounce window for live diagnostics after a keystroke"
        }
      }
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.107.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "@zjhken/jhon": "file:../typescript"
  },
  "dependencies": {},
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./ --noEmit && bun run bundle",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --outfile=out/extension.js --external:vscode",
    "watch": "tsc -watch -p ./ --noEmit & esbuild ./src/extension.ts --bundle --platform=node --format=cjs --outfile=out/extension.js --external:vscode --watch",
    "test": "bun test src/",
    "test:watch": "bun test src/ --watch"
  }
}